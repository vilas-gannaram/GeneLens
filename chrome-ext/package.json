{
	"name": "gene-lens",
	"private": true,
	"version": "0.0.1",
	"description": "A Chrome extension for instant gene lookup on double-click using gene symbol aliases and metadata.",
	"author": {
		"name": "Vilas Gannaram",
		"email": "vilasgannaram@gmail.com"
	},
	"keywords": [
		"chrome-extension",
		"gene",
		"genomics",
		"biotech",
		"bioinformatics",
		"gene-lens",
		"browser-extension",
		"lookup",
		"HGNC",
		"Ensembl"
	],
	"type": "module",
	"scripts": {
		"dev": "chokidar 'src/**/*' 'public/**/*' 'manifest.json' -c 'pnpm build'",
		"build": "tsc && vite build",
		"preview": "vite preview"
	},
	"engines": {
		"node": ">=18.0.0",
		"pnpm": ">=8.0.0"
	},
	"packageManager": "pnpm@10.9.0",
	"devDependencies": {
		"chokidar-cli": "^3.0.0",
		"typescript": "~5.7.2",
		"vite": "^6.3.1"
	},
	"dependencies": {
		"@types/chrome": "^0.0.317",
		"@types/node": "^22.15.3"
	}
}
