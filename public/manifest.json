{
	"manifest_version": 3,
	"name": "Gene Lens",
	"version": "1.0.0",
	"action": {
		"default_popup": "index.html"
	},
	"background": {
		"service_worker": "service-worker.js",
		"type": "module"
	},
	"content_scripts": [
		{
			"matches": ["<all_urls>"],
			"js": ["content-script.js"]
		}
	],
	"web_accessible_resources": [
		{
			"resources": [
				"style.css",
				"data/genes-list.json",
				"templates/gene-popup.html"
			],
			"matches": ["<all_urls>"]
		}
	],
	"permissions": ["storage", "scripting", "tabs"]
}
