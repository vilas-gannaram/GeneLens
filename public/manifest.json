{
	"manifest_version": 3,
	"name": "Gene Lens",
	"version": "1.0.0",
	"background": {
		"service_worker": "service-worker.js",
		"type": "module"
	},
	"content_scripts": [
		{
			"matches": ["<all_urls>"],
			"js": ["content-script.js"],
			"css": ["content-script.css"]
		}
	],
	"web_accessible_resources": [
		{
			"resources": ["genes-list.json"],
			"matches": ["<all_urls>"]
		}
	],
	"permissions": ["storage", "scripting", "tabs"]
}
